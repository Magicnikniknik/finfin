FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/grpc-server ./cmd/grpc-server

FROM alpine:3.20
RUN adduser -D appuser
USER appuser
WORKDIR /app
COPY --from=builder /out/grpc-server /app/grpc-server
EXPOSE 9090
ENTRYPOINT ["/app/grpc-server"]
